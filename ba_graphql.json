            "_path": "/content/dam/british-airways/en/universal-content/legalcontent/cookiepolicy/cookiepolicy",
            "content": [
              {
                "logoName": null,
                "imageRestrictions": null,
                "imageAltText": null,
                "bodyCopy": {
                  "json": null
                },
                "footerCopy": {
                  "json": null
                },
                "summaryCopy": {
                  "json": [
                    {
                      "style": "h2",
                      "nodeType": "header",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "Choosing your cookies"
                        }
                      ]
                    },
                    {
                      "nodeType": "paragraph",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "To manage or change your cookie preferences, click on the Customise button. Otherwise, read on to understand how we use cookies and similar technologies."
                        }
                      ]
                    },
                    {
                      "nodeType": "paragraph",
                      "content": [
                        {
                          "nodeType": "reference"
                        },
                        {
                          "nodeType": "line-break",
                          "content": []
                        },
                        {
                          "nodeType": "text",
                          "value": " \u003Cbutton id=\"ot-sdk-btn\" class=\"ot-sdk-show-settings\"\u003ECustomise\u003C/button\u003E"
                        }
                      ]
                    }
                  ]
                },
                "anchorLinkId": "customise",
                "linkUrl": null,
                "imageDMUrl": null,
                "imageDMUrlSmartCrop": null,
                "linkText": null,
                "title": null
              },
              {
                "logoName": null,
                "imageRestrictions": null,
                "imageAltText": null,
                "bodyCopy": {
                  "json": null
                },
                "footerCopy": {
                  "json": null
                },
                "summaryCopy": {
                  "json": [
                    {
                      "style": "h2",
                      "nodeType": "header",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "What are cookies?"
                        }
                      ]
                    },
                    {
                      "nodeType": "paragraph",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "When you travel with us online – through our websites, apps or other digital services (our services) – we want your experience to be smooth, secure and tailored to you. To help us do this, we use cookies and similar technologies. These include: "
                        }
                      ]
                    },
                    {
                      "nodeType": "unordered-list",
                      "content": [
                        {
                          "nodeType": "list-item",
                          "content": [
                            {
                              "nodeType": "text",
                              "value": "Small data files stored on your device (cookies)"
                            }
                          ]
                        },
                        {
                          "nodeType": "list-item",
                          "content": [
                            {
                              "nodeType": "text",
                              "value": "Tiny images or code snippets (pixels and tags)"
                            }
                          ]
                        },
                        {
                          "nodeType": "list-item",
                          "content": [
                            {
                              "nodeType": "text",
                              "value": "Tools or code that sit inside apps (software development kits or SDKs) "
                            }
                          ]
                        },
                        {
                          "nodeType": "list-item",
                          "content": [
                            {
                              "nodeType": "text",
                              "value": "Server-side technologies, such as scripts or event-handling services that support analytics, security and the delivery of advertising or measurement signals"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "nodeType": "paragraph",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "These technologies work together to help us understand how our services are used, keep them secure and display content that’s relevant to you. When we refer to ‘cookies’ in this policy, we mean all of these technologies. "
                        }
                      ]
                    },
                    {
                      "nodeType": "paragraph",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "This policy explains how we use them, what choices you have and how you can control technologies that aren’t essential for our services to run."
                        }
                      ]
                    },
                    {
                      "style": "h3",
                      "nodeType": "header",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "Why we use cookies and similar technologies"
                        }
                      ]
                    },
                    {
                      "nodeType": "paragraph",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "They help us to: "
                        }
                      ]
                    },
                    {
                      "nodeType": "unordered-list",
                      "content": [
                        {
                          "nodeType": "list-item",
                          "content": [
                            {
                              "nodeType": "text",
                              "value": "Keep our services safe, secure and working properly"
                            }
                          ]
                        },
                        {
                          "nodeType": "list-item",
                          "content": [
                            {
                              "nodeType": "text",
                              "value": "Remember your bookings, logins and preferences"
                            }
                          ]
                        },
                        {
                          "nodeType": "list-item",
                          "content": [
                            {
                              "nodeType": "text",
                              "value": "Understand how people use our websites and apps so that we can improve them"
                            }
                          ]
                        },
                        {
                          "nodeType": "list-item",
                          "content": [
                            {
                              "nodeType": "text",
                              "value": "Show products, services and offers that are more relevant to you"
                            }
                          ]
                        },
                        {
                          "nodeType": "list-item",
                          "content": [
                            {
                              "nodeType": "text",
                              "value": "Enable certain features, such as social media sharing and fraud-prevention checks"
                            }
                          ]
                        },
                        {
                          "nodeType": "list-item",
                          "content": [
                            {
                              "nodeType": "text",
                              "value": "Support server-side processes (for example, sending privacy-approved signals that help us measure the performance of British Airways campaigns without placing additional data on your device)"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "style": "h3",
                      "nodeType": "header",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "Controlling your cookies"
                        }
                      ]
                    },
                    {
                      "nodeType": "paragraph",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "When you first visit one of our sites or apps, you’ll see a notice explaining the types of cookies we use. Through our "
                        },
                        {
                          "data": {
                            "href": "#customise"
                          },
                          "nodeType": "link",
                          "value": "cookie preferences Customise button"
                        },
                        {
                          "nodeType": "text",
                          "value": ", you can accept or decline categories of cookies (apart from those essential for our services to run) and change your mind at any time. "
                        }
                      ]
                    },
                    {
                      "nodeType": "paragraph",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "View our "
                        },
                        {
                          "data": {
                            "href": "#cookies"
                          },
                          "nodeType": "link",
                          "value": "cookie listing"
                        },
                        {
                          "nodeType": "text",
                          "value": " for more detailed information about each cookie. "
                        }
                      ]
                    },
                    {
                      "style": "h3",
                      "nodeType": "header",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "Different cookies on different services "
                        }
                      ]
                    },
                    {
                      "nodeType": "paragraph",
                      "content": [
                        {
                          "nodeType": "text",
                          "value": "Not all of our websites, apps or digital services use every category of cookie or technology. Some may use only essential and performance cookies, while others also include advertising or social media tools. "
                        }
                      ]
                    },
                    {
                      "nodeType": "paragraph",
                      "content": [
